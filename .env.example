# =============================================
# Supabase
# =============================================

# Project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable/anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — NEVER expose to the browser!
# Used only in server-side code (Server Actions, API routes)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================
# NextAuth v5
# =============================================

# Random secret for signing JWT tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Trust proxy headers (set to true on Vercel / behind a proxy)
AUTH_TRUST_HOST=true

# =============================================
# Google OAuth (from Google Cloud Console)
# =============================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# =============================================
# Subdomain routing
# =============================================

# Root domain used to detect user subdomains (username.gallerify.app)
NEXT_PUBLIC_ROOT_DOMAIN=

# =============================================
# Lemon Squeezy
LEMONSQUEEZY_API_KEY=your_api_key_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here
NEXT_PUBLIC_LEMONSQUEEZY_STORE_ID=your_store_id_here
LEMONSQUEEZY_PRO_VARIANT_ID=your_pro_variant_id_here
LEMONSQUEEZY_PRO_MAX_VARIANT_ID=your_pro_max_variant_id_here

# Indonesian pricing variants (shown to users with x-vercel-ip-country: ID)
LEMONSQUEEZY_PRO_VARIANT_ID_ID=your_pro_indo_variant_id_here
LEMONSQUEEZY_PRO_MAX_VARIANT_ID_ID=your_pro_max_indo_variant_id_here

# Vercel custom domain API (get token from vercel.com/account/tokens)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID= (only needed if your project is under a team)